# ═══════════════════════════════════════════════════════════════
# Python Monorepo - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and customize for your local environment
# ═══════════════════════════════════════════════════════════════

# ─── General ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-secret-key

# ─── Django API (apps/django-api) ──────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=src.config.settings
DJANGO_DATABASE_URL=sqlite:///db.sqlite3
# DJANGO_DATABASE_URL=postgres://django_user:django_pass@localhost:5432/django_api
DJANGO_CELERY_BROKER_URL=redis://localhost:6379/0
DJANGO_CELERY_RESULT_BACKEND=redis://localhost:6379/0
DJANGO_CACHE_URL=redis://localhost:6379/1

# ─── Flask API (apps/flask-api) ────────────────────────────
FLASK_APP=src.app:create_app
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_SECRET_KEY=change-me-to-a-flask-secret
FLASK_DATABASE_URL=sqlite:///db.sqlite3
# FLASK_DATABASE_URL=postgres://flask_user:flask_pass@localhost:5433/flask_api
FLASK_JWT_SECRET_KEY=change-me-to-a-jwt-secret
FLASK_JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
FLASK_JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
FLASK_CELERY_BROKER_URL=redis://localhost:6379/0
FLASK_CELERY_RESULT_BACKEND=redis://localhost:6379/0
FLASK_CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# ─── Streamlit Frontend (apps/frontend) ────────────────────
STREAMLIT_API_BASE_URL=http://localhost:8000/api/v1
STREAMLIT_API_TIMEOUT=30
STREAMLIT_APP_NAME=Monorepo Dashboard
STREAMLIT_SERVER_PORT=8501

# ─── Database (PostgreSQL) ────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=monorepo

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ─── Email ─────────────────────────────────────────────────
EMAIL_BACKEND=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# ─── Sentry (Error Tracking) ──────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ─── AWS (File Storage) ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ─── External Services ────────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
